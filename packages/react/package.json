{
  "name": "@3rg0n/breakout404-react",
  "version": "0.5.0",
  "description": "React component for Breakout404 - a Breakout-style 404 page game",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rimraf dist"
  },
  "keywords": [
    "404",
    "breakout",
    "game",
    "react",
    "nextjs"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "dependencies": {
    "@3rg0n/breakout404-core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "react": "^18.3.1",
    "rimraf": "^5.0.10",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
