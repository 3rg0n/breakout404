{
  "name": "@breakout404/core",
  "version": "1.0.0",
  "description": "Core Breakout404 game engine - a Breakout-style 404 page game",
  "main": "./dist/breakout404.umd.js",
  "module": "./dist/breakout404.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/breakout404.mjs",
      "require": "./dist/breakout404.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "clean": "rimraf dist"
  },
  "keywords": [
    "404",
    "breakout",
    "game",
    "canvas"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "rimraf": "^5.0.10",
    "typescript": "^5.9.3",
    "vite": "^8.0.6",
    "vite-plugin-dts": "^4.5.4"
  }
}
