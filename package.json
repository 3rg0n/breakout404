{
  "name": "breakout404",
  "version": "0.5.0",
  "private": true,
  "description": "A 404 page Breakout game library - destroy the 404!",
  "scripts": {
    "build": "pnpm -r --filter @3rg0n/* build",
    "dev": "pnpm -r --parallel dev",
    "clean": "pnpm -r clean",
    "lint": "eslint \"packages/*/src/**/*.ts\" \"packages/*/src/**/*.tsx\"",
    "lint:fix": "eslint \"packages/*/src/**/*.ts\" \"packages/*/src/**/*.tsx\" --fix",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "404",
    "breakout",
    "game",
    "error-page"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-security": "^4.0.0",
    "jsdom": "^24.1.3",
    "prettier": "^3.8.1",
    "vitest": "^4.1.3"
  }
}
