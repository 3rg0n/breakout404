{
  "name": "pong404",
  "version": "1.0.0",
  "private": true,
  "description": "A 404 page Breakout game library - destroy the 404!",
  "scripts": {
    "build": "pnpm -r --filter @pong404/* build",
    "dev": "pnpm -r --parallel dev",
    "clean": "pnpm -r clean",
    "lint": "eslint \"packages/*/src/**/*.ts\" \"packages/*/src/**/*.tsx\"",
    "lint:fix": "eslint \"packages/*/src/**/*.ts\" \"packages/*/src/**/*.tsx\" --fix",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["404", "pong", "breakout", "game", "error-page"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.2.0",
    "vitest": "^1.2.0",
    "jsdom": "^24.0.0"
  }
}
